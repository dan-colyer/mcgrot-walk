.env.local
node_modules/
dist/
src/dev-bundle.js
.DS_Store

# Cached full-size Commons downloads — intermediate only; the runtime uses
# assets/shopfronts/atlas.jpg. Kept locally so re-cropping never re-hits Wikimedia.
assets/shopfronts/raw/

# Façade pipeline intermediates: rectified planes, sliced band tiles, and the
# QA contact sheets. Only the finished atlas ships.
assets/shopfronts/rect/
assets/shopfronts/bands/
assets/shopfronts/qa/

# D4 façade v3 intermediates: raw AI generations (generated/) and the
# per-building graded elevations (elevations/, real-photo + AI, signage
# baked in) that scripts/build-elevation-atlas.mjs packs into atlas-pages/ —
# only the packed pages ship. Re-running gen-facade-elevations.mjs/
# apply-signage.mjs/build-elevation-atlas.mjs regenerates all three.
assets/shopfronts/generated/
assets/shopfronts/elevations/

# Site build output (published to the gh-pages branch)
dist-site/
